{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "github>konflux-ci/mintmaker//config/renovate/renovate.json"
  ],
  "schedule": [
    "before 7am on Monday"
  ],
  "baseBranchPatterns": [
    "main",
    "release-1.10"
  ],
  "addLabels": [
    "konflux",
    "mintmaker"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^.tekton/.*\\.yaml$/"
      ],
      "matchStrings": ["KARGO_VERSION=(?<currentValue>v\\d+\\.\\d+\\.\\d+)"],
      "depNameTemplate": "akuity/kargo",
      "datasourceTemplate": "github-tags"
    }
  ],
  "packageRules": [
    {
      "description": "Go toolchain updates — deptriage defers approval until CI passes",
      "matchManagers": [
        "dockerfile"
      ],
      "matchPackageNames": [
        "/go-toolset/"
      ]
    },
    {
      "description": "Prioritize Konflux tekton task reference updates",
      "matchManagers": [
        "tekton"
      ],
      "prPriority": 10
    },
    {
      "matchDepNames": ["kargo", "akuity/kargo"],
      "matchUpdateTypes": ["major", "minor"],
      "enabled": false
    },
    {
      "matchDepNames": ["kargo", "akuity/kargo"],
      "matchUpdateTypes": ["patch"],
      "enabled": true,
      "groupName": "kargo-version"
    },
    {
      "matchDepNames": ["kargo", "akuity/kargo"],
      "matchBaseBranches": ["release-1.10"],
      "allowedVersions": "/^v?1\\.10\\./",
      "description": "On release-1.10, only allow kargo 1.10.x versions"
    }
  ]
}
