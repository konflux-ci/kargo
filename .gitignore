# Inverted .gitignore for Kargo Konflux Build Repository
# Everything is ignored by default; only build/CI files and the submodule are tracked.

# Ignore everything by default
*

# Include the kargo submodule directory
!kargo/

# Include core repository files
!AGENTS.md
!CODEOWNERS
!Containerfile
!LICENSE
!OWNERS
!README.md
!.gitmodules
!.gitignore

# Include configuration files
!*.yaml
!*.yml
!*.json

# Include shell scripts
!*.sh

# Include CI/CD configuration
!.github/
!.github/**

# Include build support files (e.g. npm lockfile for hermetic builds)
!build/
!build/**

# Include pipeline files
!.tekton/
!.tekton/**

# Include hack scripts
!hack/
!hack/**
